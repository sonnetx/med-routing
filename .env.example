OPENAI_API_KEY=sk-...

WEAK_MODEL=gpt-4o-mini
STRONG_MODEL=gpt-4o

# Per-router thresholds in [0,1]; score >= threshold => escalate to strong model.
THRESHOLD_SELF_REPORTED=0.15
THRESHOLD_PREDICTIVE_ENTROPY=0.40
THRESHOLD_SEMANTIC_ENTROPY=0.50
THRESHOLD_SELF_CONSISTENCY=0.40
THRESHOLD_ROUTELLM=0.50
THRESHOLD_LEARNED=0.50

SAMPLE_N=5
SAMPLE_TEMPERATURE=0.7

NLI_MODEL=cross-encoder/nli-deberta-v3-large
ENABLE_NLI=false
THRESHOLD_AUTO=0.50

# RouteLLM baseline router. Requires `pip install ".[routellm]"`.
# `mf` is the cheapest of the pretrained routers. The strong/weak model names
# below are the pair RouteLLM was *trained* on; they don't need to match the
# WEAK_MODEL/STRONG_MODEL we actually call. The mf router still needs
# OPENAI_API_KEY at score-time for embeddings.
ENABLE_ROUTELLM=false
ROUTELLM_KIND=mf
ROUTELLM_STRONG_MODEL=gpt-4-1106-preview
ROUTELLM_WEAK_MODEL=anyscale/mistralai/Mixtral-8x7B-Instruct-v0.1

# Learned router. Requires `pip install ".[learned]"` and an artifact produced
# by `python -m med_routing.train.fit ...`. The runtime router runs all four
# base signals and feeds them into the pickled sklearn pipeline; subject is
# always passed as "UNKNOWN" at inference time.
ENABLE_LEARNED=false
LEARNED_ROUTER_PATH=models/learned_router.pkl

# GDPR / data residency
HOME_REGION=US
AUDIT_DIR=audit
DB_PATH=data/med_routing.db
