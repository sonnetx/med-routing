{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by router",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (router) (rate(medr_requests_total[1m]))",
          "legendFormat": "{{router}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Escalation rate per router",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_escalation_rate",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "red", "value": 0.7 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "showThresholdMarkers": true, "showThresholdLabels": false }
    },
    {
      "id": 3,
      "type": "heatmap",
      "title": "Uncertainty score distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (le) (rate(medr_uncertainty_bucket[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "short" },
        "color": { "scheme": "Spectral", "mode": "scheme" },
        "legend": { "show": true }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cumulative spend (USD) by model",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_cost_usd_total",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Rolling accuracy by router",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_accuracy",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p50 / p95 latency by tier reached",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, tier) (rate(medr_latency_seconds_bucket[1m])))",
          "legendFormat": "p50 {{tier}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, tier) (rate(medr_latency_seconds_bucket[1m])))",
          "legendFormat": "p95 {{tier}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Token rate by model and kind",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model, kind) (rate(medr_tokens_total[1m]))",
          "legendFormat": "{{model}} / {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Routing decisions: counts by (router, escalated)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_requests_total",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }
      ]
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Reliability diagram (weak-model accuracy by uncertainty bin)",
      "description": "For each uncertainty bin, fraction of weak answers that were correct. A well-calibrated router has high accuracy in low-uncertainty bins, low accuracy in high-uncertainty bins.",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_calibration_bin_correct / clamp_min(medr_calibration_bin_total, 1)",
          "legendFormat": "{{router}} / {{bin}}",
          "refId": "A",
          "instant": true,
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Expected calibration error",
      "description": "Lower is better. ECE = sum_b (n_b/N) * |(1 - bin_midpoint) - bin_accuracy|.",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_ece",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 3,
          "min": 0,
          "max": 0.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Selective accuracy: kept-weak vs escalated",
      "description": "Did the router escalate the right questions? If kept-weak accuracy > escalated accuracy, the router is sending easier questions to the strong model — bad. We want kept-weak HIGH (router was right to keep them) and escalation gating that the strong model lifts.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_kept_weak_accuracy",
          "legendFormat": "kept-weak / {{router}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "medr_escalated_accuracy",
          "legendFormat": "escalated / {{router}}",
          "refId": "B",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "💰 Total savings vs all-strong baseline",
      "description": "How much we saved by routing some queries to the weak model instead of sending every query to GPT-4o.",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(medr_counterfactual_cost_usd_total) - sum(medr_actual_cost_usd_total)",
          "legendFormat": "savings",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Savings rate per router",
      "description": "Fraction of all-strong cost saved by routing through this uncertainty router. 1.0 = 100% saved (always weak); 0 = no savings (always strong).",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "1 - (medr_actual_cost_usd_total / clamp_min(medr_counterfactual_cost_usd_total, 0.0000001))",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Actual vs counterfactual cumulative spend",
      "description": "Solid lines: what we paid. Dashed lines: what we would have paid sending every query to GPT-4o. The gap is savings.",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_actual_cost_usd_total",
          "legendFormat": "actual / {{router}}",
          "refId": "A"
        },
        {
          "expr": "medr_counterfactual_cost_usd_total",
          "legendFormat": "all-strong / {{router}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "all-strong.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      }
    },
    {
      "id": 16,
      "type": "piechart",
      "title": "🌍 Data residency: calls by region",
      "description": "Where the data physically went. Driven by the model→processor registry. GDPR Art. 30 + Art. 46 evidence.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (region) (medr_processor_calls_total)",
          "legendFormat": "{{region}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "displayLabels": ["percent"]
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 17,
      "type": "barchart",
      "title": "Processor breakdown",
      "description": "Calls per legal processor (data controller).",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (processor, entity) (medr_processor_calls_total)",
          "legendFormat": "{{entity}} / {{processor}}",
          "refId": "A",
          "instant": true,
          "format": "time_series"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none"
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "🚨 Cross-border egress events",
      "description": "Requests where data left the configured HOME_REGION. Each label combination shows: router → foreign region.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (router, foreign_region) (medr_cross_border_total)",
          "legendFormat": "{{router}} → {{foreign_region}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 12,
      "type": "heatmap",
      "title": "Accuracy by MedMCQA subject",
      "description": "Per-subject accuracy. Watch for collapse on high-stakes subjects (Surgery, Pediatrics).",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_accuracy_by_subject",
          "legendFormat": "{{router}} / {{subject}}",
          "refId": "A",
          "instant": true,
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "color": { "scheme": "RdYlGn", "mode": "scheme" },
        "yAxis": { "axisPlacement": "left" },
        "legend": { "show": true }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["med-routing", "llm", "uncertainty"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "med-routing — Uncertainty Cascade",
  "uid": "med-routing",
  "version": 1,
  "weekStart": ""
}
