{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Routing behavior",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Cumulative requests by router",
      "description": "Total requests per router as a step line. Replayed history shows up as the initial step at startup; live traffic appears as additional steps. Click 'Run batch' on the demo UI to watch the lines climb.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (router) (medr_requests_total)",
          "legendFormat": "{{router}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineInterpolation": "stepAfter", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Escalation rate per router",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_escalation_rate",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "red", "value": 0.7 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "showThresholdMarkers": true, "showThresholdLabels": false }
    },
    {
      "id": 3,
      "type": "heatmap",
      "title": "Uncertainty score distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (le) (rate(medr_uncertainty_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "short", "max": "1" },
        "color": { "scheme": "Spectral", "mode": "scheme" },
        "legend": { "show": true }
      }
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Routing decisions per router (kept-weak vs escalated)",
      "description": "Per router: how many questions were answered by the weak model alone vs escalated to the strong model. Stacked counts.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (router) (medr_requests_total{escalated=\"false\"})",
          "legendFormat": "kept-weak",
          "refId": "A",
          "instant": true,
          "format": "time_series"
        },
        {
          "expr": "sum by (router) (medr_requests_total{escalated=\"true\"})",
          "legendFormat": "escalated",
          "refId": "B",
          "instant": true,
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "kept-weak" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "escalated" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "stacking": "normal",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": 0
      }
    },
    {
      "id": 6,
      "type": "heatmap",
      "title": "Latency distribution by tier",
      "description": "Distribution of end-to-end request latency over time. Bands shift right when the cascade escalates more often.",
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (le) (rate(medr_latency_seconds_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "axisPlacement": "left", "unit": "s" },
        "color": { "scheme": "Spectral", "mode": "scheme" },
        "legend": { "show": true }
      }
    },
    {
      "id": 61,
      "type": "stat",
      "title": "p95 latency — weak",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(medr_latency_seconds_bucket{tier=\"weak\"}[5m])))",
          "legendFormat": "weak",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "id": 62,
      "type": "stat",
      "title": "p95 latency — strong",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(medr_latency_seconds_bucket{tier=\"strong\"}[5m])))",
          "legendFormat": "strong",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value"
      }
    },

    {
      "id": 101,
      "type": "row",
      "title": "Calibration",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "panels": []
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Rolling accuracy by router",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_accuracy",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Expected calibration error",
      "description": "Lower is better. ECE = sum_b (n_b/N) * |(1 - bin_midpoint) - bin_accuracy|. Single-number summary of the reliability diagram below.",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_ece",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 3,
          "min": 0,
          "max": 0.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Reliability diagram (weak-model accuracy by uncertainty bin)",
      "description": "For each uncertainty bin, fraction of weak answers that were correct. Well-calibrated = high accuracy in low-uncertainty bins, low accuracy in high-uncertainty bins.",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_calibration_bin_correct_total / clamp_min(medr_calibration_bin_total, 1)",
          "legendFormat": "{{router}} / {{bin}}",
          "refId": "A",
          "instant": true,
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9
      }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Selective accuracy: kept-weak vs escalated",
      "description": "Did the router escalate the right questions? We want kept-weak HIGH (router was right to keep them) and escalated > kept-weak (strong model was actually needed).",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_kept_weak_accuracy",
          "legendFormat": "kept-weak / {{router}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "medr_escalated_accuracy",
          "legendFormat": "escalated / {{router}}",
          "refId": "B",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },

    {
      "id": 102,
      "type": "row",
      "title": "Economics",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "panels": []
    },
    {
      "id": 13,
      "type": "stat",
      "title": "💰 Total savings vs all-strong baseline",
      "description": "How much we saved by routing some queries to the weak model instead of sending every query to GPT-4o.",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(medr_counterfactual_cost_usd_total) - sum(medr_actual_cost_usd_total)",
          "legendFormat": "savings",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Savings rate per router",
      "description": "Fraction of all-strong cost saved by routing through this uncertainty router. 1.0 = always weak; 0 = always strong.",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "1 - (medr_actual_cost_usd_total / clamp_min(medr_counterfactual_cost_usd_total, 0.0000001))",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Actual vs counterfactual cumulative spend",
      "description": "Solid lines: what we paid. Dashed lines: what we would have paid sending every query to GPT-4o. The gap is savings.",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_actual_cost_usd_total",
          "legendFormat": "actual / {{router}}",
          "refId": "A"
        },
        {
          "expr": "medr_counterfactual_cost_usd_total",
          "legendFormat": "all-strong / {{router}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "all-strong.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cumulative spend (USD) by model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "medr_cost_usd_total",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Token rate by model and kind",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model, kind) (rate(medr_tokens_total[5m]))",
          "legendFormat": "{{model}} / {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      }
    },

    {
      "id": 103,
      "type": "row",
      "title": "Residency / GDPR (collapsed by default)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 56 },
      "panels": [
        {
          "id": 16,
          "type": "piechart",
          "title": "🌍 Data residency: calls by region",
          "description": "Where the data physically went. GDPR Art. 30 + Art. 46 evidence.",
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 57 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "expr": "sum by (region) (medr_processor_calls_total)",
              "legendFormat": "{{region}}",
              "refId": "A",
              "instant": true
            }
          ],
          "options": {
            "pieType": "donut",
            "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
            "displayLabels": ["percent"]
          },
          "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
        },
        {
          "id": 17,
          "type": "barchart",
          "title": "Processor breakdown",
          "description": "Calls per legal processor (data controller).",
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 57 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "expr": "sum by (processor, entity) (medr_processor_calls_total)",
              "legendFormat": "{{entity}} / {{processor}}",
              "refId": "A",
              "instant": true,
              "format": "time_series"
            }
          ],
          "options": {
            "orientation": "horizontal",
            "showValue": "auto",
            "stacking": "none"
          },
          "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
        },
        {
          "id": 18,
          "type": "stat",
          "title": "🚨 Cross-border egress events",
          "description": "Requests where data left the configured HOME_REGION. Stays at 0 until you configure a non-US processor.",
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 57 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "expr": "sum by (router, foreign_region) (medr_cross_border_total)",
              "legendFormat": "{{router}} → {{foreign_region}}",
              "refId": "A",
              "instant": true
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 1 },
                  { "color": "red", "value": 100 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
            "graphMode": "none",
            "colorMode": "value",
            "textMode": "value_and_name"
          }
        }
      ]
    }
  ],
