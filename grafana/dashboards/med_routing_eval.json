            "overrides": []
          }
        },
        {
          "id": 17,
          "type": "barchart",
          "title": "Processor breakdown",
          "description": "Calls per legal processor (data controller).",
          "gridPos": {
            "h": 8,
            "w": 8,
            "x": 8,
            "y": 31
          },
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "targets": [
            {
              "expr": "sum by (processor, entity) (medr_processor_calls_total)",
              "legendFormat": "{{entity}} / {{processor}}",
              "refId": "A",
