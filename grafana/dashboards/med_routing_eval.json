  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Routing behavior",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Escalation rate per router",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "medr_escalation_rate",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.4
              },
              {
                "color": "red",
                "value": 0.7
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdMarkers": true,
        "showThresholdLabels": false
      }
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Cost per router (USD)",
      "description": "Total dollars spent per router (replays + live traffic / eval pushes). Lower is better when accuracy is held constant.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (router) (medr_actual_cost_usd_total)",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 5,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": -20,
        "xField": "router",
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Calibration",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Rolling accuracy by router",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "medr_accuracy",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.7
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Expected calibration error",
      "description": "Lower is better. ECE = sum_b (n_b/N) * |(1 - bin_midpoint) - bin_accuracy|. Single-number summary of the reliability diagram below.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "medr_ece",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 3,
          "min": 0,
          "max": 0.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Reliability diagram (weak-model accuracy by uncertainty bin)",
      "description": "For each uncertainty bin, fraction of weak answers that were correct. Well-calibrated = high accuracy in low-uncertainty bins, low accuracy in high-uncertainty bins.",
      "gridPos": {
        "h": 7,
        "w": 16,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "medr_calibration_bin_correct_total / clamp_min(medr_calibration_bin_total, 1)",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "router",
            "rowField": "bin",
            "valueField": "Value"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Selective accuracy: kept-weak vs escalated",
      "description": "For each router, accuracy on questions the router KEPT (left to weak) vs questions it ESCALATED (sent to strong). Want kept-weak high (correctly held back) and escalated > kept-weak (escalations were warranted).",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "medr_kept_weak_accuracy",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "medr_escalated_accuracy",
          "refId": "B",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "router",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true
            },
            "renameByName": {
              "Value #A": "kept-weak",
              "Value #B": "escalated"
            },
            "indexByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "kept-weak"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "escalated"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": -30,
        "xField": "router",
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Economics",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "panels": []
    },
    {
      "id": 13,
      "type": "stat",
      "title": "\ud83d\udcb0 Total savings vs all-strong baseline",
      "description": "How much we saved by routing some queries to the weak model instead of sending every query to GPT-4o.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(medr_counterfactual_cost_usd_total) - sum(medr_actual_cost_usd_total)",
          "legendFormat": "savings",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "green",
                "value": 0.001
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Savings rate per router",
      "description": "Fraction of all-strong cost saved by routing through this uncertainty router. 1.0 = always weak; 0 = always strong.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "1 - (medr_actual_cost_usd_total / clamp_min(medr_counterfactual_cost_usd_total, 0.0000001))",
          "legendFormat": "{{router}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Residency / GDPR (collapsed by default)",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "panels": [
        {
          "id": 16,
          "type": "piechart",
          "title": "\ud83c\udf0d Data residency: calls by region",
          "description": "Where the data physically went. GDPR Art. 30 + Art. 46 evidence.",
          "gridPos": {
            "h": 8,
            "w": 8,
            "x": 0,
            "y": 31
          },
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "targets": [
            {
              "expr": "sum by (region) (medr_processor_calls_total)",
              "legendFormat": "{{region}}",
              "refId": "A",
              "instant": true
            }
          ],
          "options": {
            "pieType": "donut",
            "legend": {
              "displayMode": "table",
              "placement": "right",
              "values": [
                "value",
                "percent"
              ]
            },
            "displayLabels": [
              "percent"
            ]
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short"
